# Copy to .env — never commit the real file.
#
# IMPORTANT: OKX credentials do NOT go here. They live in
# ~/.okx/config.toml, created by running `okx config init` (see
# SETUP.md). This .env file only controls this app's own safety switch.

# Must be explicitly set to "true" to allow /hire to audit a LIVE
# account. Defaults to false — demo-only — until you set this.
ALLOW_LIVE=false
